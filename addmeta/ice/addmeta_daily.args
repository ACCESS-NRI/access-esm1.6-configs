# Reuse some experiment level metadata as template variables
-d=../../metadata.yaml
# Use environment data as template variables
-d=${PAYU_CURRENT_OUTPUT_DIR}/env.yaml
# Common global metadata
-m=../dataspec.yaml
# Ice only metadata
-m=dataspec.yaml
# Time and time bounds attrs
-m=../time.yaml
# Specify realm and frequency
--datavar=realm=seaIce
--datavar=freq=1day
# Files to process
${PAYU_CURRENT_OUTPUT_DIR}/ice/iceh-1daily-*.nc

{
    "$schema": "https://raw.githubusercontent.com/ACCESS-NRI/schema/main/au.org.access-nri/model/configuration/ci/2-0-0.json",
    "scheduled": {
        "default": {
            "markers": "(repro and (not repro_restart)) or access_esm1p6 or dev_config"
        },
        "dev-piControl": { },
        "dev-abrupt-4xCO2": { },
        "dev-1pctCO2": { },
        "dev-historical": { },
        "dev-esm-historical": { },
        "dev-esm-flat10": { },
        "dev-amip": { },
        "dev-1pctCO2-rad": { },
        "dev-1pctCO2-bgc": { }
    },
    "reproducibility": {
        "default": {
            "markers": "repro and (not repro_restart)"
        },
        "release-.*": {
            "model-config-tests-version": "0.2.3",
            "payu-version": "1.3.0"
        }
    },
    "qa": {
        "default": {
            "markers": "access_esm1p6 or dev_config"
        },
         "release-.*": {
            "markers": "access_esm1p6 or config",
            "model-config-tests-version": "0.2.3",
            "payu-version": "1.3.0"
        }
    },
    "default": {
        "model-config-tests-version": "main",
        "python-version": "3.11.0",
        "payu-version": "dev"
    }
}
